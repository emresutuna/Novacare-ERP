@model NovacareERP.Application.Settings.SettingsListItemViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="settings-detail-card">
    <div class="settings-detail-head">
        <i class="bi @Model.IconName"></i>
        <div>
            <h1>@Model.Title</h1>
            <p>@Model.Description</p>
        </div>
        <span>@Model.StatusText</span>
    </div>
    <div class="settings-detail-form">
        <label>Sablon Adi<input type="text" value="@Model.Title" /></label>
        <label>Varsayilan Dil<select><option>Turkce</option><option>Ingilizce</option></select></label>
        <label class="span-2">Aciklama / Metin<textarea rows="5" placeholder="Belge uzerinde gorunecek metin"></textarea></label>
    </div>
    <div class="modal-actions">
        <button class="btn-secondary-action" type="button">Onizle</button>
        <button class="btn-primary-action" type="button" data-demo-submit="@Model.Title kaydedildi."><i class="bi bi-check-lg"></i> Kaydet</button>
    </div>
</section>

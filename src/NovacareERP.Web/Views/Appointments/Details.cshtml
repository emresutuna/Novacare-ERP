@model NovacareERP.Application.Appointments.AppointmentListItemViewModel
@{
    ViewData["Title"] = "Randevu Detayı";
}

<section class="record-hero">
    <div>
        <span class="eyebrow">Randevu Kartı</span>
        <h1>@Model.Title</h1>
        <p><strong>@Model.CompanyName</strong> firması ile planlanan randevunun detayları, müşteri talebi ve görüşme notları.</p>
    </div>
    <div class="record-toolbar">
        <a class="btn-secondary-action back-action" asp-controller="Appointments" asp-action="Index"><i class="bi bi-arrow-left"></i> Geri Dön</a>
        <form asp-controller="Appointments" asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Randevuyu silmek istediğinize emin misiniz?');" style="margin:0; display:inline-block;">
            @Html.AntiForgeryToken()
            <button class="ghost-button" type="submit" style="background: #fdf2f2; color: #d11a2a; border: 0; border-radius: 6px; padding: 10px 18px; font-weight:850; font-size:14px;"><i class="bi bi-trash"></i> SİL</button>
        </form>
    </div>
</section>

<section class="customer-layout" style="grid-template-columns: minmax(620px, 1.3fr) minmax(380px, 0.7fr); align-items: start; gap: 14px;">
    <article class="panel" style="padding: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px;">
        <div class="record-section-heading" style="padding-bottom: 12px; margin-bottom: 20px; border-bottom: 1px solid var(--line);">
            <div>
                <span class="eyebrow">Randevu İçeriği</span>
                <h2>Talep ve Detaylar</h2>
            </div>
        </div>

        <div style="margin-bottom: 24px;">
            <label style="color: var(--muted); font-size: 13px; font-weight: 800; display: block; margin-bottom: 6px;">Müşteri Talebi / Beklentisi</label>
            <div style="background: var(--blue-050); border: 1px solid var(--line); border-radius: 8px; padding: 16px; font-size: 14px; line-height: 1.6; color: var(--text); min-height: 80px;">
                @(string.IsNullOrWhiteSpace(Model.CustomerDemand) ? "Belirtilen bir talep girilmemiş." : Model.CustomerDemand)
            </div>
        </div>

        <div>
            <label style="color: var(--muted); font-size: 13px; font-weight: 800; display: block; margin-bottom: 6px;">Görüşme Notları / Sonraki Aşamalar</label>
            <div style="background: var(--blue-050); border: 1px solid var(--line); border-radius: 8px; padding: 16px; font-size: 14px; line-height: 1.6; color: var(--text); min-height: 80px;">
                @(string.IsNullOrWhiteSpace(Model.Notes) ? "Görüşme notu girilmemiş." : Model.Notes)
            </div>
        </div>
    </article>

    <article class="panel" style="padding: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 8px;">
        <div class="record-section-heading" style="padding-bottom: 12px; margin-bottom: 20px; border-bottom: 1px solid var(--line);">
            <div>
                <span class="eyebrow">Planlama Bilgisi</span>
                <h2>Özet Bilgiler</h2>
            </div>
        </div>

        <div style="display: grid; gap: 18px;">
            <div>
                <span style="color: var(--muted); font-size: 12px; font-weight: 800; display: block;">MÜŞTERİ / FİRMA</span>
                <strong style="color: var(--navy-950); font-size: 16px; margin-top: 4px; display: block;">@Model.CompanyName</strong>
            </div>

            <div>
                <span style="color: var(--muted); font-size: 12px; font-weight: 800; display: block;">MÜŞTERİ YETKİLİSİ</span>
                <strong style="color: var(--navy-950); font-size: 15px; margin-top: 4px; display: block;">@Model.ContactPerson</strong>
            </div>

            <div>
                <span style="color: var(--muted); font-size: 12px; font-weight: 800; display: block;">GÖRÜŞEN TEMSİLCİNİZ</span>
                <strong style="color: var(--navy-950); font-size: 15px; margin-top: 4px; display: block;">@Model.CustomerName</strong>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; background: var(--blue-050); border: 1px solid var(--line); border-radius: 8px; padding: 14px;">
                <div>
                    <span style="color: var(--muted); font-size: 11px; font-weight: 800; display: block;">TARİH</span>
                    <strong style="color: var(--navy-950); font-size: 15px; margin-top: 2px; display: block;">@Model.Date.ToString("dd.MM.yyyy")</strong>
                </div>
                <div>
                    <span style="color: var(--muted); font-size: 11px; font-weight: 800; display: block;">SAAT</span>
                    <strong style="color: var(--navy-950); font-size: 15px; margin-top: 2px; display: block;"><i class="bi bi-clock"></i> @Model.Time.ToString("HH:mm")</strong>
                </div>
            </div>

            <div style="border-top: 1px solid var(--line); padding-top: 14px; font-size: 12px; color: var(--muted);">
                <i class="bi bi-info-circle"></i> Randevu kaydı @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm") tarihinde oluşturuldu.
            </div>
        </div>
    </article>
</section>

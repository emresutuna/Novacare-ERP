@model NovacareERP.Application.Appointments.AppointmentListViewModel
@{
    ViewData["Title"] = "Randevular";

    static string Filled(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value;

    static string ShortText(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Detay henuz girilmedi.";
        }

        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }
}

<section class="customer-hero">
    <div class="customer-title">
        <span class="eyebrow">Ziyaret & Planlama</span>
        <h1>Musteri Randevulari</h1>
        <p>Musteri ziyaretlerini, gorusme detaylarini, talepleri ve takip notlarini tek bir kullanisli ekrandan yonetin.</p>
    </div>
    <div class="page-actions customer-actions">
        <a class="btn-primary-action" asp-controller="Appointments" asp-action="Create"><i class="bi bi-plus"></i> Yeni Randevu</a>
    </div>
</section>

@if (TempData["AppointmentSaved"] is string message)
{
    <div class="notice-banner">@message</div>
}

<section class="customer-summary" aria-label="Randevu ozeti">
    <article>
        <span>Kayitli Randevu</span>
        <strong>@Model.Appointments.Count</strong>
        <small>Toplam gorusme plani</small>
    </article>
    <article style="border-top-color: var(--orange-500);">
        <span>Bugunku Gorusmeler</span>
        <strong>@Model.Appointments.Count(a => a.Date == DateOnly.FromDateTime(DateTime.Today))</strong>
        <small>Gunluk ajanda</small>
    </article>
    <article style="border-top-color: var(--blue-100);">
        <span>Musteri Havuzu</span>
        <strong>@Model.Customers.Count</strong>
        <small>Secilebilir cari karti</small>
    </article>
</section>

<section class="customer-layout list-only">
    <article class="panel table-panel">
        <div class="panel-header">
            <div>
                <span class="eyebrow">Randevu listesi</span>
                <h2>Gorusme Planlari</h2>
            </div>
            <span class="panel-count">@Model.Appointments.Count randevu</span>
        </div>

        <form class="filter-bar" asp-controller="Appointments" asp-action="Index" method="get">
            <label>
                Tarih Filtresi
                <input type="date" name="filterDate" value="@(Model.FilterDate?.ToString("yyyy-MM-dd"))" style="height:42px; border: 1px solid var(--line); border-radius: 8px; background: var(--blue-050); padding: 0 10px;" />
            </label>
            <label>
                Arama
                <input type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Firma, yetkili, baslik veya talep ara" />
            </label>
            <button class="btn-primary-action" type="submit"><i class="bi bi-search"></i> Filtrele</button>
        </form>

        <div class="appointment-list">
            @if (Model.Appointments.Count == 0)
            {
                <div class="empty-state">
                    <strong>Bu filtreye uygun randevu bulunamadi.</strong>
                    <small>Filtreyi temizleyebilir veya yeni randevu olusturabilirsiniz.</small>
                </div>
            }
            else
            {
                @foreach (var app in Model.Appointments)
                {
                    <article class="appointment-card">
                        <div class="appointment-date-box">
                            <strong>@app.Date.ToString("dd")</strong>
                            <span>@app.Date.ToString("MMM")</span>
                            <small><i class="bi bi-clock"></i> @app.Time.ToString("HH:mm")</small>
                        </div>

                        <div class="appointment-main">
                            <div class="appointment-title-row">
                                <div>
                                    <strong>@Filled(app.Title, "Planli musteri gorusmesi")</strong>
                                    <small>@ShortText(app.CustomerDemand, 140)</small>
                                </div>
                                <em class="pill blue">Cari Baglantili</em>
                            </div>

                            <div class="appointment-meta-grid">
                                <span>
                                    <i class="bi bi-building"></i>
                                    <b>Firma</b>
                                    @Filled(app.CompanyName, "Firma secilmemis")
                                </span>
                                <span>
                                    <i class="bi bi-person-lines-fill"></i>
                                    <b>Musteri Yetkilisi</b>
                                    @Filled(app.CustomerName, "Yetkili belirtilmedi")
                                </span>
                                <span>
                                    <i class="bi bi-person-check-fill"></i>
                                    <b>Gorusecek Kisi</b>
                                    @Filled(app.ContactPerson, "Emre Sutuna")
                                </span>
                                <span>
                                    <i class="bi bi-journal-text"></i>
                                    <b>Not</b>
                                    @ShortText(app.Notes, 80)
                                </span>
                            </div>
                        </div>

                        <div class="appointment-actions">
                            <a class="ghost-button" asp-controller="Appointments" asp-action="Details" asp-route-id="@app.Id"><i class="bi bi-eye"></i> Detay</a>
                            <form asp-controller="Appointments" asp-action="Delete" asp-route-id="@app.Id" method="post" onsubmit="return confirm('Randevuyu silmek istediginize emin misiniz?');">
                                @Html.AntiForgeryToken()
                                <button class="ghost-button danger" type="submit"><i class="bi bi-trash"></i> Sil</button>
                            </form>
                        </div>
                    </article>
                }
            }
        </div>
    </article>
</section>

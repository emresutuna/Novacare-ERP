@model NovacareERP.Application.SalesInvoices.SalesInvoiceListViewModel
@using NovacareERP.Domain.Enums
@{
    ViewData["Title"] = "Satislar";
    var totalAmount = Model.Invoices.Sum(invoice => invoice.GrossAmount);
}

@if (TempData["InvoiceSaved"] is string savedMessage)
{
    <div class="notice-banner">@savedMessage</div>
}

<section class="proposal-toolbar invoice-toolbar">
    <div class="module-actions">
        <a class="btn-primary-action" asp-controller="SalesInvoices" asp-action="Create" asp-route-documentType="@((int)ElectronicDocumentType.EArsiv)">
            <i class="bi bi-plus"></i> Perakende Satis
        </a>
        <a class="btn-secondary-action" asp-controller="SalesInvoices" asp-action="Create" asp-route-documentType="@((int)ElectronicDocumentType.EFatura)">
            <i class="bi bi-plus"></i> Yeni Musteri Satisi
        </a>
        <a class="btn-danger-action" asp-controller="SalesInvoices" asp-action="Create" asp-route-documentType="@((int)ElectronicDocumentType.EFatura)">
            <i class="bi bi-person-check"></i> Kayitli Musteri Satisi
        </a>
        <a class="btn-warning-action" asp-controller="SalesInvoices" asp-action="Create" asp-route-documentType="@((int)ElectronicDocumentType.None)">
            <i class="bi bi-file-earmark-text"></i> Serbest Meslek Makbuzu
        </a>
    </div>
</section>

<section class="proposal-filter-panel">
    <form class="proposal-filter-form" asp-controller="SalesInvoices" asp-action="Index" method="get">
        <div class="filter-left">
            <select name="documentType">
                <option value="">Tum Belge Tipleri</option>
                @foreach (var option in Model.DocumentTypeOptions)
                {
                    <option value="@((int)option.Value)" selected="@(Model.DocumentType == option.Value)">@option.Text</option>
                }
            </select>
            <select name="status">
                <option value="">Tum Durumlar</option>
                <option value="@((int)InvoiceStatus.Draft)" selected="@(Model.Status == InvoiceStatus.Draft)">Taslak</option>
                <option value="@((int)InvoiceStatus.Issued)" selected="@(Model.Status == InvoiceStatus.Issued)">Kesildi</option>
                <option value="@((int)InvoiceStatus.Paid)" selected="@(Model.Status == InvoiceStatus.Paid)">Odendi</option>
            </select>
        </div>
        <div class="filter-right">
            <label class="proposal-search">
                <span>Ara:</span>
                <input type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Musteri / fatura no" />
            </label>
            <button class="btn-secondary-action compact-action" type="submit"><i class="bi bi-search"></i> Ara</button>
        </div>
    </form>
</section>

<section class="proposal-list-shell">
    <div class="proposal-table invoice-table">
        <div class="proposal-row head invoice-row">
            <span>Tarih</span>
            <span>Musteri</span>
            <span>Fatura No</span>
            <span>Belge Tipi</span>
            <span>GIB Durumu</span>
            <span>Tutar</span>
        </div>
        @if (Model.Invoices.Count == 0)
        {
            <div class="empty-state proposal-empty-state">
                <div class="empty-state-icon"><i class="bi bi-receipt"></i></div>
                <div>
                    <span class="eyebrow">Henuz satis faturasi yok</span>
                    <strong>Ilk satis isleminizi buradan kaydedin.</strong>
                    <small>Faturalar olustukca musteri, belge tipi, GIB durumu ve tutar bilgileri bu listede gorunecek.</small>
                </div>
                <a class="btn-primary-action" asp-controller="SalesInvoices" asp-action="Create"><i class="bi bi-plus"></i> Yeni Satis Faturasi</a>
            </div>
        }
        else
        {
            @foreach (var invoice in Model.Invoices)
            {
                <a class="proposal-row proposal-row-link invoice-row" asp-controller="SalesInvoices" asp-action="Details" asp-route-id="@invoice.Id">
                    <span>@invoice.IssueDate.ToString("dd.MM.yyyy")</span>
                    <span>@invoice.CustomerName</span>
                    <span>@invoice.InvoiceNumber</span>
                    <span><span class="pill blue">@invoice.DocumentTypeText</span></span>
                    <span><span class="pill @(invoice.DocumentStatus == ElectronicDocumentStatus.Accepted ? "green" : invoice.DocumentStatus == ElectronicDocumentStatus.Pending ? "orange" : "blue")">@invoice.DocumentStatusText</span></span>
                    <span>@invoice.GrossAmount.ToString("N2") @invoice.CurrencyCode</span>
                </a>
            }
        }
    </div>
</section>

<section class="proposal-total-strip">
    <span>Listelenen satis faturasi toplami</span>
    <strong>@totalAmount.ToString("N2") TL</strong>
</section>

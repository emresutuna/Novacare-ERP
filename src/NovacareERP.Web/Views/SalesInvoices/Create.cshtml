@model NovacareERP.Application.SalesInvoices.SalesInvoiceFormViewModel
@using NovacareERP.Application.Invoices
@{
    ViewData["Title"] = Model.Title;
    var subtotal = Model.Items.Sum(item => item.TotalAmount);
    var taxTotal = Model.Items.Sum(item => item.TotalAmount * item.TaxRate / 100);
    var grandTotal = subtotal + taxTotal;
    var isEdit = Model.Id != Guid.Empty;
}

<form class="customer-create invoice-create" asp-controller="SalesInvoices" asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : (Guid?)null)" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit)
    {
        <input type="hidden" name="id" value="@Model.Id" />
    }

    <input type="hidden" name="DocumentStatus" value="@((int)Model.DocumentStatus)" />
    <input type="hidden" name="Status" value="@((int)Model.Status)" />
    <input type="hidden" name="ExchangeRate" value="@Model.ExchangeRate" />
    <input type="hidden" name="CustomerId" value="@Model.CustomerId" />

    <section class="record-hero">
        <div>
            <span class="eyebrow">Satis faturasi</span>
            <h1>@Model.Title</h1>
            <p>Musteri bilgileri, belge detaylari, urun/hizmet kalemleri ve e-belge durumunu sistemin satis akisina uygun sekilde duzenleyin.</p>
        </div>
        <div class="record-toolbar">
            <a class="btn-secondary-action back-action" asp-controller="SalesInvoices" asp-action="Index"><i class="bi bi-arrow-left"></i> Geri Don</a>
            <button class="btn-primary-action save-action" type="submit">KAYDET</button>
        </div>
    </section>

    <section class="record-workspace">
        <aside class="record-side-nav" aria-label="Satis faturasi bolumleri">
            <button class="active" type="button" data-tab-target="invoice-info">
                <i class="bi bi-receipt"></i>
                <span><strong>Fatura</strong><small>Musteri ve tarih</small></span>
            </button>
            <button type="button" data-tab-target="invoice-items">
                <i class="bi bi-list-check"></i>
                <span><strong>Kalemler</strong><small>Urun ve tutarlar</small></span>
            </button>
            <button type="button" data-tab-target="invoice-edoc">
                <i class="bi bi-send-check"></i>
                <span><strong>E-Belge</strong><small>GIB bilgileri</small></span>
            </button>
        </aside>

        <section class="record-card">
            <div class="record-tab-panel active" data-tab-panel="invoice-info">
                <div class="record-section-heading">
                    <div>
                        <span class="eyebrow">Satis faturasi bilgileri</span>
                        <h2>Musteri ve belge detaylari</h2>
                    </div>
                </div>
                <div class="record-grid">
                    <div class="record-field wide">
                        <label>Musteri Unvani</label>
                        <input name="CustomerName" value="@Model.CustomerName" placeholder="Perakende / musteri unvani" />
                    </div>
                    <div class="record-field">
                        <label>Vergi / TC Kimlik No</label>
                        <input name="CustomerTaxNumber" value="@Model.CustomerTaxNumber" />
                    </div>
                    <div class="record-field">
                        <label>Fatura No</label>
                        <input name="InvoiceNumber" value="@Model.InvoiceNumber" />
                    </div>
                    <div class="record-field">
                        <label>Fatura Tarihi</label>
                        <input name="IssueDate" value="@Model.IssueDate.ToString("yyyy-MM-dd")" type="date" />
                    </div>
                    <div class="record-field">
                        <label>Vade Tarihi</label>
                        <input name="DueDate" value="@Model.DueDate?.ToString("yyyy-MM-dd")" type="date" />
                    </div>
                    <div class="record-field">
                        <label>Para Birimi</label>
                        <select name="CurrencyCode">
                            <option selected="@(Model.CurrencyCode == "TRY")">TRY</option>
                            <option selected="@(Model.CurrencyCode == "USD")">USD</option>
                            <option selected="@(Model.CurrencyCode == "EUR")">EUR</option>
                        </select>
                    </div>
                    <div class="record-field wide">
                        <label>Aciklama</label>
                        <textarea name="Description" rows="3">@Model.Description</textarea>
                    </div>
                </div>
            </div>

            <div class="record-tab-panel" data-tab-panel="invoice-items">
                <div class="record-section-heading">
                    <div>
                        <span class="eyebrow">Satis kalemleri</span>
                        <h2>Urun ve hizmet satirlari</h2>
                    </div>
                </div>
                <div class="proposal-items">
                    <div class="proposal-item-row head">
                        <span>Urun / Hizmet</span>
                        <span>Miktar</span>
                        <span>Birim Fiyat</span>
                        <span>KDV</span>
                        <span>Tutar</span>
                    </div>
                    @for (var i = 0; i < Model.Items.Count; i++)
                    {
                        var item = Model.Items[i];
                        <div class="proposal-item-row">
                            <span><input name="Items[@i].ProductOrServiceName" value="@item.ProductOrServiceName" /></span>
                            <span><input name="Items[@i].Quantity" value="@item.Quantity" type="number" step="0.01" /></span>
                            <span><input name="Items[@i].UnitPrice" value="@item.UnitPrice" type="number" step="0.01" /></span>
                            <span><input name="Items[@i].TaxRate" value="@item.TaxRate" type="number" step="1" /></span>
                            <span><input name="Items[@i].TotalAmount" value="@item.TotalAmount" type="number" step="0.01" /></span>
                        </div>
                    }
                </div>
                <div class="proposal-totals">
                    <div><span>Ara Toplam</span><strong>@subtotal.ToString("N2") @Model.CurrencyCode</strong></div>
                    <div><span>KDV</span><strong>@taxTotal.ToString("N2") @Model.CurrencyCode</strong></div>
                    <div class="grand-total"><span>Genel Toplam</span><strong>@grandTotal.ToString("N2") @Model.CurrencyCode</strong></div>
                </div>
            </div>

            <div class="record-tab-panel" data-tab-panel="invoice-edoc">
                <div class="record-section-heading">
                    <div>
                        <span class="eyebrow">E-belge</span>
                        <h2>Belge tipi ve GIB durumu</h2>
                    </div>
                </div>
                <div class="edoc-panel">
                    <p class="helper-note">@Model.IntegrationNote</p>
                    <div class="record-grid">
                        <div class="record-field">
                            <label>Belge Tipi</label>
                            <select name="DocumentType">
                                @foreach (var option in Model.DocumentTypeOptions)
                                {
                                    <option value="@((int)option.Value)" selected="@(Model.DocumentType == option.Value)">@option.Text</option>
                                }
                            </select>
                        </div>
                        <div class="record-field">
                            <label>GIB Durumu</label>
                            <input readonly value="@InvoiceDisplayText.GetDocumentStatusText(Model.DocumentStatus)" />
                        </div>
                        <div class="record-field">
                            <label>ETTN</label>
                            <input readonly value="@(Model.Ettn ?? "-")" />
                        </div>
                        <div class="record-field wide">
                            <label>Belge UUID</label>
                            <input readonly value="@(Model.DocumentUuid ?? "-")" />
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </section>
</form>
